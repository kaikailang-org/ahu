# tests/restart_transient_normal.kai — Transient policy + Normal exit → no restart.
#
# Coverage: the Transient policy with a body that returns Unit
# cleanly. trap-exit delivers "Normal"; Transient does NOT
# restart on Normal (only on Crashed). The supervisor returns
# Unit after one body run.

import actor
import spawn
import ahu.restart

fn body(parent: Pid[String]) : Unit / Actor[String] + Link + Console = {
  Link.link(parent)
  Stdout.print("body: ran (clean exit)")
}

fn run() : Unit / Actor[String] + Spawn + Link + Cancel + Console = {
  restart.with_restart(Transient, restart.default_limit(), body)
  Stdout.print("supervisor: returned")
}

fn main() : Int / Console + Spawn + Link + Cancel = {
  with_mailbox { run() }
  0
}
