# tests/restart_intensity_escalate.kai — intensity exceeded → Cancel.raise().
#
# Coverage: the intensity-exceeded escalation path of
# with_restart. Permanent policy + body that always crashes +
# intensity=2 means: body runs twice (count 0 and 1), the
# third would exceed intensity, so with_restart calls
# Cancel.raise(). The caller wraps with a Cancel handler so
# the program observes the escalation as a raised effect —
# the BEAM-faithful semantics now that `lnds/kaikai#103`
# closed in PR #122 (the kaikai runtime converts trap-exit'd
# child Cancel.raise() to "Crashed" *before* any user-level
# Cancel handler can intercept, so the outer Cancel handler
# only catches the supervisor's own Cancel.raise() at the
# escalation site — never the child's).
#
# Verifies that escalation composes through Cancel: a layered
# parent (an outer `with_restart` watching this one) would
# observe escalation through the standard Link/trap-exit
# channel as a "Crashed" message in its own mailbox.

import actor
import spawn
import ahu.restart

fn body(parent: Pid[String]) : Unit / Actor[String] + Link + Console + Cancel = {
  Link.link(parent)
  Stdout.print("body: ran (will crash)")
  Cancel.raise()
}

fn run() : Unit / Actor[String] + Spawn + Link + Console = {
  handle {
    restart.with_restart(Permanent, Limit(2), body)
  } with Cancel {
    raise(resume) -> Stdout.print("supervisor: escalated")
  }
}

fn main() : Int / Console + Spawn + Link = {
  with_mailbox { run() }
  0
}
